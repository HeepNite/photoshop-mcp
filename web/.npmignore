# Override web/.gitignore so the built UI bundle (web/dist) ships with the
# package while excluding source/tooling that aren't needed at runtime.
# Patterns are anchored to the web/ root so they don't match files inside
# web/dist (e.g. web/dist/index.html, web/dist/assets/index-*.js).
/node_modules
/src
/public
/index.html
/vite.config.ts
/tsconfig*.json
/*.tsbuildinfo
/package.json
/package-lock.json
/components.json
/.gitignore
.DS_Store
*.local
